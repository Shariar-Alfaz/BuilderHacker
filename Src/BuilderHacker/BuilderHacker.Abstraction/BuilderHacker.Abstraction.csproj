<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Deterministic>true</Deterministic>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>SAProduction.BuilderHacker.Abstraction</PackageId>
    <Title>BuilderHacker Abstraction</Title>
    <Description>Abstraction layer for BuilderHacker - a code generator for builder pattern implementation.</Description>
	  <Authors>Shariar Alfaz</Authors>
	  <Company>SA Production</Company>
    <PackageProjectUrl>https://github.com/Shariar-Alfaz/BuilderHacker</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/Shariar-Alfaz/BuilderHacker</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>builder;builder-pattern;source-generator;roslyn;code-generation;dotnet;csharp</PackageTags>
    <Version>1.0.0</Version>
    <PackageIcon>logo.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
	  <Copyright>
		  Copyright © 2026 SA Production
	  </Copyright>
	  <IncludeSymbols>true</IncludeSymbols>
	  <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\logo.png" Pack="true" PackagePath="\" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
