<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Deterministic>true</Deterministic>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>SAProduction.BuilderHacker.Abstraction</PackageId>
    <Title>BuilderHacker Abstraction</Title>
    <Description>Abstraction layer for BuilderHacker - a code generator for builder pattern implementation.</Description>
    <Authors>BuilderHacker Contributors</Authors>
    <PackageProjectUrl>https://github.com/Shariar-Alfaz/BuilderHacker</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/Shariar-Alfaz/BuilderHacker</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>builder;pattern;code-generation;dotnet</PackageTags>
    <Version>1.0.0</Version>
  </PropertyGroup>

</Project>
